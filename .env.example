# Host file paths used by Docker Compose bind mounts.

LYRA_CONFIG_FILE=./lyra_data/config/lyra.toml
LYRA_SERVICE_ACCOUNT_FILE=./secrets/service-account.json

# Runtime environment passed to every Lyra app container.

LYRA_POSTGRES_HOST=replace-with-reachable-postgis-host
LYRA_POSTGRES_PORT=5432
LYRA_POSTGRES_DB=lyra
LYRA_POSTGRES_USER=lyra
LYRA_POSTGRES_PASSWORD=change-me
LYRA_AGENT_API_KEY=replace-with-a-random-agent-secret
LYRA_ADMIN_API_KEY=replace-with-a-different-admin-secret
