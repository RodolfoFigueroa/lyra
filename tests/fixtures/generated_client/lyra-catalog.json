{
  "catalog_fingerprint": "4f279a0e62055783547862f437202157e13995a55d31f7c81c899310f7bd7fb1",
  "client_schema_version": 1,
  "json_schema_dialect": "https://json-schema.org/draft/2020-12/schema",
  "metrics": [
    {
      "description": "Exercise nested, referenced, enum, and batch inputs.",
      "name": "advanced_score",
      "output": {
        "batched_columns": [
          {
            "description": "Score for {label}.",
            "name": "score_{key}",
            "nullable": false,
            "source": "sectors",
            "type": "number",
            "unit": "score"
          }
        ],
        "columns": [],
        "kind": "table"
      },
      "request_schema": {
        "$defs": {
          "ScoringConfig": {
            "additionalProperties": false,
            "properties": {
              "mode": {
                "enum": [
                  "fast",
                  "precise"
                ],
                "type": "string"
              },
              "weights": {
                "additionalProperties": {
                  "type": "number"
                },
                "default": {
                  "distance": 1.0
                },
                "type": "object"
              }
            },
            "required": [
              "mode"
            ],
            "type": "object"
          }
        },
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "config": {
            "$ref": "#/$defs/ScoringConfig"
          },
          "location": {
            "type": "object"
          },
          "sectors": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "key": {
                  "pattern": "^[a-z][a-z0-9_]*$",
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              },
              "required": [
                "key",
                "value"
              ],
              "type": "object"
            },
            "maxItems": 10,
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "location",
          "config",
          "sectors"
        ],
        "type": "object"
      },
      "spatial_inputs": {
        "location": "location"
      }
    },
    {
      "description": "Calculate representative accessibility values.",
      "name": "job_accessibility",
      "output": {
        "batched_columns": [],
        "columns": [
          {
            "description": "Accessible jobs.",
            "name": "jobs",
            "nullable": false,
            "type": "number",
            "unit": "jobs"
          }
        ],
        "kind": "table"
      },
      "request_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "limit": {
            "default": 50,
            "minimum": 1,
            "type": "integer"
          },
          "location": {
            "oneOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "data_type": {
                    "const": "cvegeo_list"
                  },
                  "value": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "required": [
                  "value"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "data_type": {
                    "const": "met_zone_code"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "value"
                ],
                "type": "object"
              }
            ]
          },
          "threshold": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          }
        },
        "required": [
          "location"
        ],
        "type": "object"
      },
      "spatial_inputs": {
        "location": "location"
      }
    },
    {
      "description": "Export a representative raster file.",
      "name": "raster_export",
      "output": {
        "extensions": [
          ".tif"
        ],
        "kind": "file",
        "media_type": "image/tiff"
      },
      "request_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "bounds": {
            "type": "object"
          },
          "palette": {
            "default": [
              "#000000",
              "#ffffff"
            ],
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "bounds"
        ],
        "type": "object"
      },
      "spatial_inputs": {
        "bounds": "bounds"
      }
    }
  ]
}
