{
  "schema_version": 3,
  "plugin": {
    "name": "lyra-smoke-plugin",
    "version": "0.1.0"
  },
  "metrics": [
    {
      "name": "smoke_table_metric",
      "description": "Return the submitted value for each input feature.",
      "entrypoint": "smoke_plugin.runner:plugin",
      "inputs": {
        "location": {
          "kind": "location"
        },
        "value": {
          "description": "Value copied into each output row.",
          "kind": "integer"
        }
      },
      "output": {
        "kind": "table",
        "columns": [
          {
            "name": "value",
            "type": "integer",
            "unit": "count",
            "description": "Submitted value."
          }
        ]
      }
    },
    {
      "name": "smoke_file_metric",
      "description": "Write a small text artifact for the submitted features.",
      "entrypoint": "smoke_plugin.runner:plugin",
      "inputs": {
        "location": {
          "kind": "location"
        }
      },
      "output": {
        "kind": "file",
        "media_type": "text/plain",
        "extensions": [
          ".txt"
        ]
      }
    },
    {
      "name": "smoke_cancel_metric",
      "description": "Emit progress and observe cancellation before returning.",
      "entrypoint": "smoke_plugin.runner:plugin",
      "inputs": {
        "location": {
          "kind": "location"
        },
        "value": {
          "description": "Value copied into each output row.",
          "kind": "integer"
        }
      },
      "output": {
        "kind": "table",
        "columns": [
          {
            "name": "value",
            "type": "integer",
            "unit": "count",
            "description": "Submitted value."
          }
        ]
      }
    }
  ]
}
